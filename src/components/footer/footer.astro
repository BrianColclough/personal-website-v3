---
import { Icon } from "astro-icon/components";
const currentYear = new Date().getFullYear();

interface SocialLink {
    label: string;
    href: string;
    icon: string;
    colorClass: string;
}

const socialLinks: SocialLink[] = [
    { label: "GitHub", href: "https://github.com/briancolclough", icon: "github", colorClass: "text-secondary bg-secondary-container" },
    { label: "Instagram", href: "https://instagram.com/brian_colclough", icon: "instagram", colorClass: "text-tertiary bg-tertiary-container" }
];
---

<footer class="mt-20 border-t-2 border-primary/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
        <!-- Social Icons -->
        <div class="flex justify-center gap-6 mb-12">
            {socialLinks.map(({ label, href, icon, colorClass }, i) => (
                <a
                    href={href}
                    aria-label={label}
                    target="_blank"
                    rel="noopener noreferrer"
                    class={`p-3 ${colorClass} rounded-2xl border-2 border-black transition-transform hover:-translate-y-2`}
                    style={`transform: rotate(${i % 2 === 0 ? '-3deg' : '4deg'}); box-shadow: var(--shadow-sticker);`}
                >
                    <Icon name={icon} class="w-8 h-8" />
                </a>
            ))}
        </div>

        <!-- Tagline -->
        <h3 class="text-2xl md:text-3xl font-display font-bold text-text-primary mb-12" style="letter-spacing: -0.05em;">
            Running, Coding, and Creating. Let's Connect!
        </h3>

        <!-- Copyright -->
        <div class="pt-8">
            <p class="text-xs md:text-sm font-mono text-text-muted">
                &copy; {currentYear} Brian Colclough. Made with caffeine and code.
            </p>
        </div>
    </div>
</footer>
