---
import { documentToHtmlString } from "@contentful/rich-text-html-renderer";
import Layout from "../../layouts/Layout.astro";
import { contentfulClient, type BlogEntryRO } from "../../lib/contentful";
import { calculateReadTime } from "../../lib/reading-time";
import type { BlogPost } from "./types/blogPost";

const contentfulEntries = await contentfulClient.getEntries<BlogEntryRO>({
    content_type: "blogPost",
});

const contentfulPosts: BlogPost[] = contentfulEntries.items.map((item) => {
    const { title, datePosted, summary, slug, content, tags } = item.fields;
    return {
        title: title as string,
        slug: slug as string,
        summary: summary as string,
        content: documentToHtmlString(content),
        datePosted: new Date(datePosted as string).toLocaleDateString(),
        rawDate: new Date(datePosted as string),
        source: "contentful" as const,
        tags: tags as string[] || [],
    };
});

const { getCollection } = await import("astro:content");
const markdownEntries = await getCollection("blog", ({ data }) => data.draft !== true);
const markdownPosts = markdownEntries.map((entry: any) => {
    const slug = entry.data.slug || entry.slug;
    const contentText = entry.body || "";
    return {
        title: entry.data.title,
        slug,
        summary: entry.data.summary,
        content: contentText,
        datePosted: entry.data.datePosted.toLocaleDateString(),
        rawDate: entry.data.datePosted,
        source: "markdown" as const,
        tags: entry.data.tags || [],
    };
});

const posts: BlogPost[] = [...contentfulPosts, ...markdownPosts].sort(
    (a, b) => b.rawDate.getTime() - a.rawDate.getTime(),
);

function formatDate(dateString: string): string {
    const date = new Date(dateString);
    return date.toLocaleDateString('en-US', { 
        year: 'numeric', month: 'long', day: 'numeric' 
    });
}

// Neo-Brutalist recurring styles for grid mapping
const cardStyles = [
  { bg: "bg-surface-container-lowest", text: "text-black", border: "border-primary", shadow: "shadow-[6px_6px_0px_#702ddc]", sticker: "sticker-purple", typeTag: "Code" },
  { bg: "bg-surface-container-lowest", text: "text-black", border: "border-secondary", shadow: "shadow-[6px_6px_0px_#22c55e]", sticker: "sticker-green", typeTag: "Tech" },
  { bg: "bg-surface-container-lowest", text: "text-black", border: "border-tertiary", shadow: "shadow-[6px_6px_0px_#ff66b2]", sticker: "sticker-pink", typeTag: "Ideas" },
  { bg: "bg-surface-container-lowest", text: "text-black", border: "border-error", shadow: "shadow-[6px_6px_0px_#ef4444]", sticker: "sticker-pink", typeTag: "Life" },
  { bg: "bg-surface-container-lowest", text: "text-black", border: "border-black", shadow: "shadow-[6px_6px_0px_#1a1a1a]", sticker: "sticker-purple", typeTag: "Rambling" }
];
---

<Layout title="Brian Colclough | Blog" description="Thoughts on AI, software engineering, photography, and the intersection of technology and creativity.">
    
    <!-- Hero Section -->
    <section class="border-b-4 border-black bg-surface pb-16 pt-56 lg:pt-64 relative overflow-hidden">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
            <h1 class="text-5xl md:text-7xl lg:text-8xl font-display font-black text-black leading-tight tracking-tight mb-8" transition:name="page-title">
                Writing & <br/>Thoughts.
            </h1>
            <p class="text-xl md:text-2xl text-text-secondary leading-relaxed max-w-3xl mx-auto mb-12 font-medium">
                Exploring the intersection of <span class="bg-primary text-white px-2 py-1 font-bold">artificial intelligence</span>, 
                software engineering, and <span class="bg-secondary text-black px-2 py-1 font-bold">creative expression</span>.
            </p>
            
            <!-- Blog Stats -->
            <div class="flex justify-center items-center gap-8 text-sm font-mono font-bold text-black uppercase tracking-widest">
                <div class="flex items-center gap-2 border-2 border-black px-4 py-2 bg-white shadow-sticker">
                    <div class="w-3 h-3 bg-secondary rounded-none border border-black"></div>
                    <span>{posts.length} articles</span>
                </div>
            </div>
        </div>
        
        <!-- Abstract Shapes -->
        <div class="absolute -top-12 -left-12 w-48 h-48 bg-tertiary rounded-full mix-blend-multiply opacity-50 blur-2xl"></div>
        <div class="absolute bottom-0 right-12 w-64 h-64 bg-primary rounded-full mix-blend-multiply opacity-20 blur-3xl text-white"></div>
    </section>

    <!-- Main Content -->
    <main class="py-24 bg-surface">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            
            {posts.length > 0 ? (
                <section>
                    <div class="columns-1 sm:columns-2 lg:columns-3 gap-8">
                        {posts.map((post, index) => {
                            const style = cardStyles[index % cardStyles.length];
                            return (
                                <a href={`/blog/${post.slug}`} class={`card-asymmetric mb-8 break-inside-avoid block ${style.bg} border-4 ${style.border} ${style.text} ${style.shadow} group no-underline focus-ring`}>
                                    <div class="flex flex-col h-full">
                                        <div class="flex items-center gap-3 text-sm font-mono font-bold mb-4 opacity-80 uppercase tracking-widest">
                                            <time>{formatDate(post.datePosted)}</time>
                                        </div>
                                        
                                        <h3 class="text-3xl font-display font-black leading-tight mb-4 group-hover:scale-105 transition-transform duration-200 origin-left" transition:name={`blog-title-${post.slug}`}>
                                            {post.title}
                                        </h3>
                                        
                                        <p class="text-lg font-medium opacity-90 leading-relaxed mb-4 line-clamp-3">
                                            {post.summary || post.content.replace(/<[^>]*>?/gm, '')}
                                        </p>
                                        
                                        <div class="mt-auto pt-6 flex items-center justify-between">
                                            <span class="font-bold underline decoration-4 underline-offset-4">
                                                Read →
                                            </span>
                                            
                                            <div class="flex items-center gap-2">
                                                {(post.tags && post.tags.length > 0 ? post.tags : [style.typeTag]).map((tag: string) => (
                                                    <span class={`sticker ${style.sticker}`}>{tag}</span>
                                                ))}
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            );
                        })}
                    </div>
                </section>
            ) : (
                <section class="text-center py-24">
                    {/* Empty State */}
                    <div class="max-w-md mx-auto card-asymmetric bg-surface-container-lowest border-4 border-black p-8 shadow-sticker-lg rotate-1">
                        <div class="text-6xl mb-6">📝</div>
                        <h3 class="text-3xl font-display font-black text-primary mb-4">
                            Coming Soon
                        </h3>
                        <p class="text-lg text-text-secondary mb-8 font-medium">
                            I'm working on articles about AI, photography, and software engineering. 
                            Check back soon for new content!
                        </p>
                        <a href="/" class="btn btn-primary text-xl px-8 py-4">
                            Return Home
                        </a>
                    </div>
                </section>
            )}
            
        </div>
    </main>
</Layout>
