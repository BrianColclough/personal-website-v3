---
import { calculateReadTime } from "../lib/reading-time";

type Props = {
    title: string;
    date: string;
    content?: string;
    slug?: string;
    source?: "contentful" | "markdown";
    summary?: string;
};

const { title, date, content, slug, source, summary } = Astro.props;

// Format date nicely
const formattedPublishedDate = new Date(date).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});

// Extract headings for table of contents
function extractHeadings(
    content: string,
): Array<{ id: string; text: string; level: number }> {
    const headingRegex = /<h([1-6])[^>]*id="([^"]*)"[^>]*>([^<]*)<\/h[1-6]>/g;
    const headings = [];
    let match;

    while ((match = headingRegex.exec(content)) !== null) {
        headings.push({
            level: parseInt(match[1]),
            id: match[2],
            text: match[3],
        });
    }

    return headings;
}

const readingTime = content ? calculateReadTime(content) : "5 min read";
const headings = content ? extractHeadings(content) : [];
const hasTableOfContents = headings.length > 1;
---

<div class="min-h-screen bg-surface">
    <!-- Article Header -->
    <header class="py-16 md:py-24 border-b-2 border-primary/20 bg-surface mt-10">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="max-w-3xl">
                <!-- Meta Information -->
                <div class="flex items-center gap-4 text-sm font-mono text-text-secondary mb-8">
                    <div class="sticker sticker-purple">{formattedPublishedDate}</div>
                    <div class="sticker sticker-green">{readingTime}</div>
                </div>

                <!-- Article Title -->
                <h1
                    class="text-3xl sm:text-5xl lg:text-7xl font-display font-extrabold text-black leading-[1.05] tracking-tight mb-8"
                    transition:name={slug ? `blog-title-${slug}` : undefined}
                >
                    {title}
                </h1>

                <!-- Article Intro/Summary -->
                <p class="text-xl md:text-2xl text-text-secondary leading-relaxed border-l-8 border-primary pl-6 py-2 font-medium">
                    {summary}
                </p>
            </div>
        </div>
    </header>

    <!-- Main Content Area -->
    <main class="relative py-16 md:py-24">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-start">
                
                <!-- Table of Contents (Desktop Sidebar) -->
                {hasTableOfContents && (
                    <aside class="w-full lg:w-72 flex-shrink-0 lg:sticky top-32 order-2 lg:order-1">
                        <div class="card-asymmetric border-2 border-black p-6 bg-secondary-container">
                            <h3 class="text-lg font-display font-black text-black mb-4 uppercase tracking-widest border-b-2 border-black pb-2">
                                Contents
                            </h3>
                            <nav>
                                <ul class="space-y-3 font-sans font-bold">
                                    {headings.map((heading) => (
                                        <li class={`${heading.level > 2 ? "ml-4 text-sm font-medium" : ""}`}>
                                            <a
                                                href={`#${heading.id}`}
                                                class="block text-black hover:text-primary transition-colors duration-200"
                                            >
                                                → {heading.text}
                                            </a>
                                        </li>
                                    ))}
                                </ul>
                            </nav>
                        </div>
                    </aside>
                )}

                <!-- Article Content -->
                <article class={`flex-1 min-w-0 w-full prose-neo-brutalist ${!hasTableOfContents ? 'mx-auto max-w-3xl' : ''} order-1 lg:order-2`}>
                    {source === "contentful" ? (
                        <div set:html={content} />
                    ) : (
                        <slot />
                    )}
                </article>
            </div>
        </div>
    </main>

    <!-- Article Footer -->
    <footer class="border-t-2 border-black/10 py-24 bg-surface-container">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h3 class="text-4xl font-display font-black text-primary mb-8 tracking-tight">
                Keep Exploring!
            </h3>
            <div class="flex justify-center gap-6">
                <a href="/blog" data-astro-prefetch class="btn btn-secondary text-lg border-2 border-black text-black">
                    ← Back to Blog
                </a>
            </div>
        </div>
    </footer>
</div>

<style is:global>
    /* Neo-Brutalist Prose Styling */
    .prose-neo-brutalist {
        font-family: var(--font-sans);
        font-size: 1.125rem;
        line-height: 1.8;
        color: var(--color-text-primary);
    }

    /* Headings */
    .prose-neo-brutalist h1,
    .prose-neo-brutalist h2,
    .prose-neo-brutalist h3,
    .prose-neo-brutalist h4,
    .prose-neo-brutalist h5,
    .prose-neo-brutalist h6 {
        font-family: var(--font-display);
        font-weight: 900;
        color: black;
        margin-top: 3.5rem;
        margin-bottom: 1.25rem;
        line-height: 1.2;
        letter-spacing: -0.02em;
        scroll-margin-top: 6rem;
    }

    .prose-neo-brutalist h2 {
        font-size: 2.25rem;
        border-bottom: 6px solid var(--color-primary);
        padding-bottom: 0.5rem;
        display: inline-block;
    }

    .prose-neo-brutalist h3 {
        font-size: 1.75rem;
        border-left: 4px solid var(--color-secondary);
        padding-left: 1rem;
    }
    
    .prose-neo-brutalist h4 { font-size: 1.5rem; }
    
    .prose-neo-brutalist p {
        margin-bottom: 1.75rem;
    }

    /* Links */
    .prose-neo-brutalist a {
        color: var(--color-primary);
        text-decoration: underline;
        text-decoration-thickness: 3px;
        text-underline-offset: 4px;
        transition: all 0.2s;
        font-weight: 800;
    }
    .prose-neo-brutalist a:hover {
        background-color: var(--color-primary-container);
        color: var(--color-primary);
    }

    /* Code styling */
    .prose-neo-brutalist code:not(pre code) {
        font-family: var(--font-mono);
        background-color: var(--color-tertiary-container);
        color: black;
        padding: 0.2em 0.5em;
        border-radius: 4px;
        font-size: 0.9em;
        font-weight: 800;
        border: 2px solid black;
        box-shadow: 2px 2px 0px rgba(0,0,0,0.1);
    }

    .prose-neo-brutalist pre {
        background-color: #1a1a1a;
        color: #f8f8f2;
        padding: 1.5rem;
        border-radius: 12px;
        border: 4px solid black;
        box-shadow: var(--shadow-sticker-lg);
        overflow-x: auto;
        margin: 2.5rem 0;
        font-family: var(--font-mono);
        font-size: 0.95rem;
    }

    /* Blockquotes */
    .prose-neo-brutalist blockquote {
        background-color: var(--color-tertiary-container);
        color: black;
        border: 4px solid black;
        box-shadow: 6px 6px 0px var(--color-tertiary);
        padding: 1.5rem 2rem;
        margin: 3rem 0;
        border-radius: 4px;
        font-style: italic;
        font-weight: 700;
        font-size: 1.25rem;
        transform: rotate(-1deg);
    }
    
    .prose-neo-brutalist blockquote p {
        margin-bottom: 0;
    }

    /* Lists */
    .prose-neo-brutalist ul,
    .prose-neo-brutalist ol {
        margin: 2rem 0;
        padding-left: 2rem;
    }
    .prose-neo-brutalist li {
        margin-bottom: 0.75rem;
        position: relative;
    }
    .prose-neo-brutalist ul li::before {
        content: "▹";
        position: absolute;
        left: -1.5rem;
        color: var(--color-primary);
        font-weight: 900;
        font-size: 1.25em;
    }

    /* Images */
    .prose-neo-brutalist img {
        border-radius: 8px;
        border: 4px solid black;
        box-shadow: var(--shadow-sticker-lg);
        margin: 3rem auto;
        max-width: 100%;
        height: auto;
    }

    /* Tables */
    .prose-neo-brutalist table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        margin: 3rem 0;
        border: 4px solid black;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: var(--shadow-sticker);
    }
    .prose-neo-brutalist th {
        background-color: var(--color-secondary);
        color: black;
        padding: 1rem;
        text-align: left;
        font-family: var(--font-display);
        font-weight: 900;
        border-bottom: 4px solid black;
    }
    .prose-neo-brutalist td {
        padding: 1rem;
        border-bottom: 2px solid black;
        background-color: white;
    }
    .prose-neo-brutalist tr:last-child td {
        border-bottom: none;
    }
</style>
